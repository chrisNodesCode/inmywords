generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model JournalEntry {
  id              String   @id @default(cuid())
  userId          String
  sortOrder       Int      @default(0)
  content         String
  title           String?
  mood            String?
  tags            String[]
  aiSuggestedTags String[]
  aiSuggestions          Json?
  tagQuotes              Json?
  aiConfirmed            Boolean  @default(false)
  isChildhoodMemory      Boolean  @default(false)
  isFunctionalImpairment Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Optional parent project (playground organizer).
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  todos         Todo[]
  shoppingItems ShoppingItem[]

  @@index([userId])
  @@index([projectId])
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

// Playground To-dos — co-located with journal data so tools can cross-reference
// entries/tags down the road. Scoped by userId like JournalEntry.
model Todo {
  id          String    @id @default(cuid())
  userId      String
  sortOrder   Int       @default(0)
  title       String
  note        String?
  priority    Priority?
  dueDate     DateTime?
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Optional cross-reference to a journal entry. SetNull so deleting an entry
  // just unlinks the todo rather than removing it.
  entryId String?
  entry   JournalEntry? @relation(fields: [entryId], references: [id], onDelete: SetNull)

  // Optional project association (playground Project module).
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entryId])
  @@index([projectId])
}

// Playground Project — lightweight organizer that Prompts and Todos can be
// linked to. Right now just a name; will get richer fields later.
model Project {
  id        String   @id @default(cuid())
  userId    String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prompts Prompt[]
  todos   Todo[]
  entries JournalEntry[]

  @@index([userId])
}

// Playground Prompt — LLM prompt drafts. Content is TipTap JSON (same as
// JournalEntry) so we can reuse the IMWEditor.
model Prompt {
  id        String   @id @default(cuid())
  userId    String
  sortOrder Int      @default(0)
  projectId String?
  title     String?
  content   String   // TipTap JSON
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
}

// Shopping lists — playground module. Each list is typically a retailer
// (Target, Walmart, Amazon, etc.). Items belong to exactly one list.
model ShoppingList {
  id        String   @id @default(cuid())
  userId    String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items ShoppingItem[]

  @@index([userId])
}

model ShoppingItem {
  id          String    @id @default(cuid())
  userId      String
  listId      String
  sortOrder   Int       @default(0)
  name        String
  quantity    Int?
  unitPrice   Float?
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  list ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)

  // Optional cross-reference to a journal entry (mirrors Todo.entryId).
  entryId String?
  entry   JournalEntry? @relation(fields: [entryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([listId])
  @@index([entryId])
}

model UserPreferences {
  id               String   @id @default(cuid())
  userId           String   @unique
  accent           String   @default("slate")
  font             String   @default("noto")
  darkMode         Boolean  @default(false)
  deepWriteDefault Boolean  @default(false)
  editorFontSize   Int      @default(17)
  editorLineWidth  String   @default("mid")
  autoAnalyze      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
