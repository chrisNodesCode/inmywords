generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model JournalEntry {
  id              String   @id @default(cuid())
  userId          String
  sortOrder       Int      @default(0)
  content         String
  title           String?
  mood            String?
  tags            String[]
  aiSuggestedTags String[]
  aiSuggestions          Json?
  tagQuotes              Json?
  aiConfirmed            Boolean  @default(false)
  isChildhoodMemory      Boolean  @default(false)
  isFunctionalImpairment Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Optional parent project (playground organizer).
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  todos         Todo[]
  shoppingItems ShoppingItem[]

  @@index([userId])
  @@index([projectId])
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

// Playground To-dos — co-located with journal data so tools can cross-reference
// entries/tags down the road. Scoped by userId like JournalEntry.
model Todo {
  id          String    @id @default(cuid())
  userId      String
  sortOrder   Int       @default(0)
  title       String
  note        String?
  priority    Priority?
  dueDate     DateTime?
  phone       String?
  url         String?
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Optional cross-reference to a journal entry. SetNull so deleting an entry
  // just unlinks the todo rather than removing it.
  entryId String?
  entry   JournalEntry? @relation(fields: [entryId], references: [id], onDelete: SetNull)

  // Optional project association (playground Project module).
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entryId])
  @@index([projectId])
}

// Playground Project — lightweight organizer that Prompts and Todos can be
// linked to. Right now just a name; will get richer fields later.
model Project {
  id        String   @id @default(cuid())
  userId    String
  name      String
  sortOrder Int      @default(0)
  // Default set of structured Note field keys applied to new notes created in
  // this project (the per-project "template"). See app/chris/_lib/noteFields.
  noteFields String[]
  // Up to 3 project-specific custom field definitions, each a slot:
  // { key: "c1"|"c2"|"c3", label: string, type: "text"|"number"|"currency"|"boolean" }.
  customFields Json?
  // Saved comparison config for the Compare tab:
  // { fields: string[], sortBy: string|null, sortDir: "asc"|"desc" }.
  compareConfig Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prompts  Prompt[]
  todos    Todo[]
  entries  JournalEntry[]
  messages Message[]
  notes    Note[]

  @@index([userId])
}

// Playground Prompt — LLM prompt drafts. Content is TipTap JSON (same as
// JournalEntry) so we can reuse the IMWEditor.
model Prompt {
  id        String   @id @default(cuid())
  userId    String
  sortOrder Int      @default(0)
  projectId String?
  title     String?
  content   String   // TipTap JSON
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
}

// Playground Notes — freeform research/reference notes (e.g. apartment listings
// to compare later). Content is TipTap JSON (same as JournalEntry/Prompt) so we
// can reuse the IMWEditor. Organized by project; no status/actionable concept —
// these are reference material, not to-dos.
model Note {
  id        String   @id @default(cuid())
  userId    String
  sortOrder Int      @default(0)
  projectId String?
  title     String?
  content   String   // TipTap JSON

  // Optional structured data for building comparison views later. Each is
  // nullable and only surfaced when toggled on (enabledFields) or non-empty.
  amount   Float? // currency (USD)
  distance Float? // miles
  rating   Int? // 1–5 stars
  date     DateTime? // a relevant date (availability, visit, deadline…)
  phone    String?
  email    String?
  url      String?
  address  String? // physical address

  // Which optional fields are shown/active on this note. New notes inherit the
  // parent project's `noteFields` template. A field also displays when it holds
  // a value, regardless of this list.
  enabledFields String[]

  // Values for the parent project's custom fields, keyed by slot (c1/c2/c3).
  // Shape: { c1?: string|number|boolean, c2?: ..., c3?: ... }. The label/type
  // for each slot lives on Project.customFields.
  customValues Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
}

// Playground Messaging — drafts of Slack/email/text messages that Claude
// "translates" into a neurotypical-professional register, then the writer edits
// into a final draft. Three stages: draft → response → finalDraft.
//   - draft:      the writer's raw message (TipTap JSON)
//   - response:   Claude's suggested rewrite (plain text)
//   - finalDraft: the writer's edited, send-ready version (TipTap JSON)
model Message {
  id         String   @id @default(cuid())
  userId     String
  sortOrder  Int      @default(0)
  channel    String   @default("email") // "slack" | "email" | "text"
  draft      String   // TipTap JSON
  response   String?  // plain text from Claude
  finalDraft String?  // TipTap JSON
  status     String   @default("draft") // "draft" | "response" | "final"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
}

// Editable persona presets for Messaging translation. One row per (user, key);
// `key` is a stable MessageMode ("professional" | "dating" | "friends"). `prompt`
// is the system prompt the owner can edit in the UI. Seeded from defaults in
// lib/translate-message.ts on first load.
model MessagePreset {
  id        String   @id @default(cuid())
  userId    String
  key       String
  label     String
  prompt    String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId])
}

// Shopping lists — playground module. Each list is typically a retailer
// (Target, Walmart, Amazon, etc.). Items belong to exactly one list.
model ShoppingList {
  id        String   @id @default(cuid())
  userId    String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items ShoppingItem[]

  @@index([userId])
}

model ShoppingItem {
  id          String    @id @default(cuid())
  userId      String
  listId      String
  sortOrder   Int       @default(0)
  name        String
  quantity    Int?
  unitPrice   Float?
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  list ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)

  // Optional cross-reference to a journal entry (mirrors Todo.entryId).
  entryId String?
  entry   JournalEntry? @relation(fields: [entryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([listId])
  @@index([entryId])
}

model UserPreferences {
  id               String   @id @default(cuid())
  userId           String   @unique
  accent           String   @default("slate")
  font             String   @default("noto")
  darkMode         Boolean  @default(false)
  deepWriteDefault Boolean  @default(false)
  editorFontSize   Int      @default(17)
  editorLineWidth  String   @default("mid")
  autoAnalyze      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ── Budget (playground /chris/budget) ────────────────────────────────────────
// Forecasting budget ported from Airtable (categories → items → calendar).
// Chain: BudgetCategory 1—* BudgetItem 1—* BudgetEntry(date). The amount lives
// on the item (running-total anchor); a BudgetEntry is one planned occurrence on
// a date (the "calendar"). Month is derived from the date — no rollup table.

enum BudgetKind {
  DEBIT // money out  → subtracts from running total
  CREDIT // money in  → adds to running total
}

model BudgetCategory {
  id        String       @id @default(cuid())
  userId    String
  name      String
  kind      BudgetKind   @default(DEBIT)
  color     String? // optional hex for UI chips
  sortOrder Int          @default(0)
  items     BudgetItem[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([userId])
}

model BudgetItem {
  id         String          @id @default(cuid())
  userId     String
  name       String
  amount     Float // tracked for running totals (USD)
  note       String?
  sortOrder  Int             @default(0)
  categoryId String?
  category   BudgetCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  entries    BudgetEntry[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([userId])
  @@index([categoryId])
}

// Manually-tracked actual account balances (no bank API). The "checking"
// balance is the starting point for the calendar's running total; "savings"
// seeds the Savings view. Editable via the graphical cards in the UI.
model BudgetAccount {
  id        String   @id @default(cuid())
  userId    String
  key       String // "checking" | "savings" (room for more later)
  label     String
  balance   Float    @default(0)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId])
}

model BudgetEntry {
  id        String     @id @default(cuid())
  userId    String
  date      DateTime // the planned day (forecast, up to ~1yr out)
  // Per-occurrence amount override. null = use the linked item's canonical
  // amount (default); a value delinks just this occurrence's amount, so editing
  // the item amount updates every instance EXCEPT overridden ones.
  amountOverride Float?
  paid      Boolean    @default(false) // manually confirmed transaction occurred
  sortOrder Int        @default(0)
  itemId    String
  item      BudgetItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId])
  @@index([itemId])
  @@index([userId, date])
}
